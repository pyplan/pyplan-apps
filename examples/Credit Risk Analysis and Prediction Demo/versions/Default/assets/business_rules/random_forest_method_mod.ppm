\n}\n\nresult = _params", "title": "Random Forest Parameters", "nodeClass": "variable", "moduleId": "random_forest_method_mod", "x": 330, "y": 90, "z": 1, "w": "180", "h": "40", "description": "Hyperparameters used by the Random Forest classifier in this module.", "units": null, "color": "#FFFF4B", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "dict", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297131+00:00", "last_modified_at": "2026-03-12T18:56:02.433237+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000288, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "roc_auc_rfm", "definition": "from sklearn.metrics import roc_auc_score\n\n_roc_auc = roc_auc_score(y_test, probability_prediction_rfm)\n\nresult = _roc_auc", "title": "ROC AUC - Random Forest Method", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 780, "y": 300, "z": 1, "w": 180, "h": 40, "description": "Area Under the ROC Curve (ROC AUC) computed from test labels and predicted probabilities.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297134+00:00", "last_modified_at": "2026-03-18T12:59:09.569722+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0018019999999999993, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "confusion_matrix_rfm", "definition": "from sklearn.metrics import confusion_matrix\n\n_cm = confusion_matrix(y_test, model_prediction_rfm)\n_labels_actual = [\"Actual - Good\", \"Actual - Bad\"]\n_labels_predicted = [\"Predicted - Good\", \"Predicted - Bad\"]\n_confusion_matrix = xr.DataArray(\n    _cm,\n    coords={\"Actual\": _labels_actual, \"Predicted\": _labels_predicted},\n    dims=[\"Actual\", \"Predicted\"],\n)\n\nresult = _confusion_matrix", "title": "Confusion Matrix - Random Forest Method", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 330, "y": 370, "z": 1, "w": "180", "h": "40", "description": "Confusion matrix as an xarray DataArray with labeled actual and predicted classes.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataArray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297137+00:00", "last_modified_at": "2026-03-12T18:56:02.639879+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00266, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "f1_score_rfm", "definition": "from sklearn.metrics import f1_score\n\nresult = f1_score(y_test, model_prediction_rfm)", "title": "F1 score rfm", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 780, "y": 370, "z": 1, "w": 180, "h": 40, "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"created_at": "2026-03-18T12:58:23.911441+00:00", "last_modified_at": "2026-03-18T12:59:12.848830+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-18T13:20:00.486582+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.0020800000000000003, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "score_rfm", "definition": "result = random_forest_method.score(x_train, y_train)", "title": "Score - Random Forest Method", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 560, "y": 160, "z": 1, "w": 180, "h": 40, "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"created_at": "2026-03-18T13:00:02.108319+00:00", "last_modified_at": "2026-03-18T13:00:41.845681+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-18T13:20:00.486587+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.006737000000000001, "title_translation