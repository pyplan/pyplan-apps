{"nodeList": [{"identifier": "random_forest_method", "definition": "from sklearn.ensemble import RandomForestClassifier\n\n_params = parameters_rfm\n_model = RandomForestClassifier(\n    n_estimators=_params[\"n_estimators\"],\n    max_features=_params[\"max_features\"],\n    max_depth=_params[\"max_depth\"],\n    random_state=fixed_random_state,\n)\n_model = _model.fit(x_train, y_train)\n\nresult = _model", "title": "Random Forest Method", "nodeClass": "variable", "moduleId": "random_forest_method_mod", "x": 330, "y": 160, "z": 1, "w": "180", "h": "40", "description": "Trains and returns the Random Forest classifier using selected hyperparameters and the current training dataset.", "units": null, "color": "#CB98FF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "RandomForestClassifier", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297097+00:00", "last_modified_at": "2026-03-13T13:11:17.576590+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.662989, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "accuracy_rfm", "definition": "from sklearn.metrics import accuracy_score\n\n_accuracy = accuracy_score(y_test, model_prediction_rfm)\n\nresult = _accuracy", "title": "Accuracy - Random Forest Method", "nodeClass": "outputnode", "moduleId": "random_forest_method_mod", "x": 330, "y": 300, "z": 1, "w": "180", "h": "40", "description": "Accuracy score of the Random Forest model on the test dataset.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486553+00:00", "last_modified_at": "2026-03-12T18:56:02.608229+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001569, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "model_prediction_rfm", "definition": "# Class prediction on test data\n_prediction = random_forest_method.predict(x_test)\n\nresult = _prediction", "title": "Model Prediction - Random Forest Method", "nodeClass": "variable", "moduleId": "random_forest_method_mod", "x": 330, "y": 230, "z": 1, "w": "180", "h": "40", "description": "Predicted class labels on the test dataset produced by the trained Random Forest model.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297106+00:00", "last_modified_at": "2026-03-12T18:56:02.593994+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.003297, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "feature_importance_rfm", "definition": "# Build feature importance table\n_feature_names = normalized_data.columns[normalized_data.columns != \"Risk_bad\"]\n_importances = random_forest_method.feature_importances_\n_df = pd.DataFrame({\"feature\": _feature_names, \"importance\": _importances})\n\n# Sort and format rank for reporting\n_df = _df.sort_values(by=\"importance\", ascending=False)\n_df[\"Rank\"] = _df[\"importance\"].rank(ascending=False, method=\"first\").astype(int).astype(str)\n_df[\"Rank\"] = _df[\"Rank\"].apply(lambda _x: \"0\" + _x if len(_x) == 1 else _x)\n_df[\"feature\"] = _df[\"Rank\"] + \". \" + _df[\"feature\"]\n_df = _df.drop(columns=\"Rank\").set_index(\"feature\")\n\nresult = _df", "title": "Feature Importance - Random Forest Method", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 330, "y": 440, "z": 1, "w": "180", "h": "40", "description": "Feature importance ranking from the trained Random Forest model, sorted descending.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297110+00:00", "last_modified_at": "2026-03-12T18:56:08.203328+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.004809000000000001, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "probability_prediction_rfm", "definition": "# Probability of the positive class (class = 1)\n_probability = random_forest_method.predict_proba(x_test)[:, 1]\n\nresult = _probability", "title": "Probability Prediction - Random Forest Method", "nodeClass": "variable", "moduleId": "random_forest_method_mod", "x": 560, "y": 230, "z": 1, "w": "180", "h": "40", "description": "Predicted probability for the positive class on the test dataset.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297117+00:00", "last_modified_at": "2026-03-12T18:56:02.601514+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.004122, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "roc_curve_rfm", "definition": "from sklearn.metrics import roc_curve\nimport plotly.graph_objects as go\n\n_fpr, _tpr, _thresholds = roc_curve(y_test, probability_prediction_rfm)\nthresholds = _thresholds\n\n_trace_random = go.Scatter(\n    x=[0, 1],\n    y=[0, 1],\n    name=\"Random\",\n)\n_trace_roc = go.Scatter(\n    x=_fpr,\n    y=_tpr,\n    name=\"ROC Curve\",\n)\n\n_data = [_trace_random, _trace_roc]\n_layout = go.Layout(\n    yaxis=dict(title=\"True Positive Rate\"),\n    xaxis=dict(title=\"False Positive Rate\"),\n)\n_fig = go.Figure(_data, _layout)\n_fig.layout.xaxis.update({\"anchor\": \"x\", \"domain\": [0.05, 0.95]})\n_fig.layout.yaxis.update({\"anchor\": \"y\", \"domain\": [0.05, 0.95]})\n\nresult = _fig", "title": "ROC Curve - Random Forest Method", "nodeClass": "report", "moduleId": "random_forest_method_mod", "x": 560, "y": 300, "z": 1, "w": "180", "h": "40", "description": "ROC curve chart (Plotly) comparing model performance against a random baseline.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "Figure", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297120+00:00", "last_modified_at": "2026-03-12T18:56:02.658446+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.002007, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "precision_score_rfm", "definition": "from sklearn.metrics import precision_score\n\n_precision = precision_score(y_test, model_prediction_rfm)\n\nresult = _precision", "title": "Precision Score - Random Forest Method", "nodeClass": "outputnode", "moduleId": "random_forest_method_mod", "x": 560, "y": 370, "z": 1, "w": "180", "h": "40", "description": "Precision score of the Random Forest model on the test dataset.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486568+00:00", "last_modified_at": "2026-03-12T18:56:02.616725+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001582, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"iden