{"nodeList": [{"identifier": "gaussian_naive_bayes_method", "definition": "from sklearn.naive_bayes import GaussianNB\n\n_model = GaussianNB()\n_trained_model = _model.fit(x_train, y_train)\n\nresult = _trained_model", "title": "Gaussian Naive Bayes Method", "nodeClass": "variable", "moduleId": "gaussian_naive_bayes_method_mod", "x": 340, "y": 220, "z": 1, "w": "180", "h": "40", "description": "Trains and returns a Gaussian Naive Bayes classifier with the current training dataset.", "units": null, "color": "#CB98FF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "GaussianNB", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297151+00:00", "last_modified_at": "2026-03-13T13:49:52.968794+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0020540000000000003, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "a6ff0a263c07842679cff4eec707cf188", "definition": "result = x_train", "title": "X Train", "nodeClass": "alias", "moduleId": "gaussian_naive_bayes_method_mod", "x": 80, "y": 150, "z": 1, "w": "180", "h": "40", "description": "Matriz de variables predictoras del set de entrenamiento balanceado con SMOTE. Se utiliza para entrenar el modelo Gaussian Naive Bayes.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "x_train", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "ndarray", "metadata": {"last_modified_at": "2026-03-12T18:40:50.563497+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "af31fa2a7eba54950aa6072bb6305d63b", "definition": "result = y_train", "title": "Y Train", "nodeClass": "alias", "moduleId": "gaussian_naive_bayes_method_mod", "x": 80, "y": 220, "z": 1, "w": "180", "h": "40", "description": "Vector objetivo del set de entrenamiento balanceado con SMOTE. Contiene la etiqueta real para el ajuste del modelo.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "y_train", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "ndarray", "metadata": {"last_modified_at": "2026-03-12T18:57:21.431659+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "ab3a2098e550748d8a6a93040615417ee", "definition": "result = x_test", "title": "X Test", "nodeClass": "alias", "moduleId": "gaussian_naive_bayes_method_mod", "x": 80, "y": 290, "z": 1, "w": "180", "h": "40", "description": "Matriz de variables predictoras del set de prueba. Se usa para generar predicciones y evaluar performance fuera de muestra.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "x_test", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "ndarray", "metadata": {"last_modified_at": "2026-03-12T18:57:23.400162+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "a77756b9613914cb696089416fca9cd82", "definition": "result = y_test", "title": "Y Test", "nodeClass": "alias", "moduleId": "gaussian_naive_bayes_method_mod", "x": 80, "y": 360, "z": 1, "w": "180", "h": "40", "description": "Vector objetivo real del set de prueba. Es la referencia para calcular m\u00e9tricas de evaluaci\u00f3n del modelo.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "y_test", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "ndarray", "metadata": {"last_modified_at": "2026-03-12T18:57:25.142269+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "model_prediction_gnb", "definition": "# Predict class labels for test set\n_prediction = gaussian_naive_bayes_method.predict(x_test)\n\nresult = _prediction", "title": "Model Prediction - Gaussian NB Method", "nodeClass": "variable", "moduleId": "gaussian_naive_bayes_method_mod", "x": 340, "y": 290, "z": 1, "w": "180", "h": "40", "description": "Genera las predicciones de clase sobre el set de prueba usando el modelo Gaussian Naive Bayes entrenado.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297157+00:00", "last_modified_at": "2026-03-12T18:59:27.952645+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000207, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "accuracy_gnb", "definition": "from sklearn.metrics import accuracy_score\n\n# Compute overall accuracy\n_accuracy = accuracy_score(y_test, model_prediction_gnb)\n\nresult = _accuracy", "title": "Accuracy - Gaussian NB Method", "nodeClass": "outputnode", "moduleId": "gaussian_naive_bayes_method_mod", "x": 340, "y": 360, "z": 1, "w": "180", "h": "40", "description": "M\u00e9trica de exactitud global (Accuracy): proporci\u00f3n de casos correctamente clasificados sobre el total del set de prueba.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486617+00:00", "last_modified_at": "2026-03-13T13:50:31.238343+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000666, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "confusion_matrix_gnb", "definition": "from sklearn.metrics import confusion_matrix\n\n# Use model class order to keep matrix labels aligned\n_class_labels = [str(_label) for _label in gaussian_naive_bayes_method.classes_]\n_cm = confusion_matrix(y_test, model_prediction_gnb, labels=gaussian_naive_bayes_method.classes_)\n\n_actual_labels = [f\"Actual - {_label}\" for _label in _class_labels]\n_predicted_labels = [f\"Predicted - {_label}\" for _label in _class_labels]\n\n_cm_da = xr.DataArray(\n    _cm,\n    coords={\"Actual\": _actual_labels, \"Predicted\": _predicted_labels},\n    dims=[\"Actual\", \"Predicted\"],\n)\n\nresult = _cm_da", "title": "Confusion Matrix - Gaussian NB Method", "nodeClass": "report", "moduleId": "gaussian_naive_bayes_method_mod", "x": 340, "y": 440, "z": 1, "w": "180", "h": "40", "description": "Matriz de confusi\u00f3n del modelo en el set de prueba, etiquetada din\u00e1micamente seg\u00fan las clases reales del clasificador.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataArray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297163+00:00", "last_modified_at": "2026-03-13T13:50:34.800773+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001667, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "probability_prediction_gnb", "definition": "# Predict class probabilities for test set\n_probabilities = gaussian_naive_bayes_method.predict_proba(x_test)\n\n# Keep probability of positive class (column index 1)\n_positive_class_probability = _probabilities[:, 1]\n\nresult = _positive_class_probability", "title": "Probability Prediction - Gaussian NB Method", "nodeClass": "variable", "moduleId": "gaussian_naive_bayes_method_mod", "x": 620, "y": 290, "z": 1, "w": "180", "h": "40", "description": "Calcula la probabilidad estimada de la clase positiva para cada observaci\u00f3n del set de prueba. Se usa para ROC y AUC.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297166+00:00", "last_modified_at": "2026-03-13T13:50:23.310961+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000397, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "roc_curve_gnb", "definition": "from sklearn.metrics import roc_curve\nimport plotly.graph_objects as go\n\n# Compute ROC points\n_fpr, _tpr, _thresholds = roc_curve(y_test, probability_prediction_gnb)\n\n_random_trace = go.Scatter(\n    x=[0, 1],\n    y=[0, 1],\n    name=\"Random\",\n    mode=\"lines\",\n)\n\n_roc_trace = go.Scatter(\n    x=_fpr,\n    y=_tpr,\n    name=\"ROC Curve\",\n    mode=\"lines\",\n)\n\n_layout = go.Layout(\n    xaxis={\"title\": \"False Positive Rate\"},\n    yaxis={\"title\": \"True Positive Rate\"},\n)\n\n_fig = go.Figure(data=[_random_trace, _roc_trace], layout=_layout)\n_fig.layout.xaxis.update({\"anchor\": \"x\", \"domain\": [0.05, 0.95]})\n_fig.layout.yaxis.update({\"anchor\": \"y\", \"domain\": [0.05, 0.95]})\n\nresult = _fig", "title": "ROC Curve - Gaussian NB Method", "nodeClass": "report", "moduleId": "gaussian_naive_bayes_method_mod", "x": 620, "y": 360, "z": 1, "w": "180", "h": "40", "description": "Construye la curva ROC del modelo a partir de probabilidades predichas y la compara contra una referencia aleatoria.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "Figure", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297169+00:00", "last_modified_at": "2026-03-13T13:50:32.911848+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.021038, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "precision_score_gnb", "definition": "from sklearn.metrics import precision_score\n\n# Compute precision for positive class\n_precision = precision_score(y_test, model_prediction_gnb)\n\nresult = _precision", "title": "Precision Score - Gaussian NB Method", "nodeClass": "outputnode", "moduleId": "gaussian_naive_bayes_method_mod", "x": 620, "y": 440, "z": 1, "w": "180", "h": "40", "description": "M\u00e9trica de precisi\u00f3n (Precision): porcentaje de predicciones positivas que realmente pertenecen a la clase positiva.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486622+00:00", "last_modified_at": "2026-03-13T13:50:36.433371+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.002534, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "recall_score_gnb", "definition": "from sklearn.metrics import recall_score\n\n# Compute recall for positive class\n_recall = recall_score(y_test, model_prediction_gnb)\n\nresult = _recall", "title": "Recall - Gaussian NB Method", "nodeClass": "outputnode", "moduleId": "gaussian_naive_bayes_method_mod", "x": 620, "y": 520, "z": 1, "w": "180", "h": "40", "description": "M\u00e9trica de sensibilidad (Recall): porcentaje de casos positivos reales correctamente detectados por el modelo.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486627+00:00", "last_modified_at": "2026-03-13T13:50:26.097758+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001142, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "roc_auc_gnb", "definition": "from sklearn.metrics import roc_auc_score\n\n# Compute area under ROC curve\n_roc_auc = roc_auc_score(y_test, probability_prediction_gnb)\n\nresult = _roc_auc", "title": "ROC AUC - Gaussian NB Method", "nodeClass": "report", "moduleId": "gaussian_naive_bayes_method_mod", "x": 880, "y": 360, "z": 1, "w": "180", "h": "40", "description": "\u00c1rea bajo la curva ROC (AUC). Resume la capacidad discriminatoria del modelo entre clases.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297178+00:00", "last_modified_at": "2026-03-13T13:50:43.357522+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001345, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "node1_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy1", "definition": "result = 0", "title": "Datasets", "nodeClass": "text", "moduleId": "gaussian_naive_bayes_method_mod", "x": 50, "y": 100, "z": -1, "w": "240", "h": "480", "description": "Regi\u00f3n visual que agrupa los nodos de datos de entrada (train/test) usados por el modelo Gaussian Naive Bayes.", "units": null, "color": "#EEEEEE", "errorInDef": false, "nodeInfo": {"showInputs": 0, "showOutputs": 0, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 1}, "nodeFont": "Arial Black,15", "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-12T18:59:28.008827+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "node1_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy1", "definition": "result = 0", "title": "Model and Metrics", "nodeClass": "text", "moduleId": "gaussian_naive_bayes_method_mod", "x": 310, "y": 100, "z": -1, "w": "780", "h": "480", "description": "Regi\u00f3n visual que agrupa entrenamiento del modelo, predicciones y m\u00e9tricas de evaluaci\u00f3n.", "units": null, "color": "#EEEEEE", "errorInDef": false, "nodeInfo": {"showInputs": 0, "showOutputs": 0, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 1}, "nodeFont": "Arial Black,15", "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-13T13:50:47.592190+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "f1_score_gnb", "definition": "from sklearn.metrics import f1_score\n\nresult = f1_score(y_test, model_prediction_gnb)", "title": "F1 Score - Logistic Regression Method", "nodeClass": "report", "moduleId": "gaussian_naive_bayes_method_mod", "x": 340, "y": 520, "z": 1, "w": 180, "h": 40, "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"created_at": "2026-03-18T13:15:36.304514+00:00", "last_modified_at": "2026-03-18T13:16:04.866225+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-18T13:20:00.486632+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.005434, "title_translations": {"es-AR": "", "en-US": "", "pt-BR": ""}, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "score_gnb", "definition": "result = gaussian_naive_bayes_method.score(x_train, y_train)", "title": "Score - Gaussian NB Method", "nodeClass": "report", "moduleId": "gaussian_naive_bayes_method_mod", "x": 620, "y": 220, "z": 1, "w": 180, "h": 40, "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "float", "metadata": {"created_at": "2026-03-18T13:16:20.444367+00:00", "last_modified_at": "2026-03-18T13:16:40.468517+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-18T13:20:00.486637+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.0014099999999999998, "title_translations": {"es-AR": "", "en-US": "", "pt-BR": ""}, "description_translations": null, "persistenceType": "in_definition"}]}