{"nodeList": [{"identifier": "acd3b2d839c6748f6a1969c751a07e21e", "definition": "result = random_forest_method", "title": "Random Forest Method", "nodeClass": "alias", "moduleId": "predictions_functions_mod", "x": 750, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Trains and returns the Random Forest classifier using selected hyperparameters and the current training dataset.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "random_forest_method", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "RandomForestClassifier", "metadata": {"last_modified_at": "2026-03-12T18:45:40.589629+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "a2c565a1880bf4e89b76e7d9ee06beaee", "definition": "result = logistic_regression_method", "title": "Logistic Regression Method", "nodeClass": "alias", "moduleId": "predictions_functions_mod", "x": 750, "y": 310, "z": 1, "w": "180", "h": "40", "description": "Trains and returns the Logistic Regression classifier using configured regularization parameters and training data.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "logistic_regression_method", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "LogisticRegression", "metadata": {"last_modified_at": "2026-03-12T19:02:25.863716+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "ae5a80b7287fb40179953f656bc2e30a2", "definition": "result = gaussian_naive_bayes_method", "title": "Gaussian Naive Bayes Method", "nodeClass": "alias", "moduleId": "predictions_functions_mod", "x": 750, "y": 550, "z": 1, "w": "180", "h": "40", "description": "Trains and returns a Gaussian Naive Bayes classifier with the current training dataset.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "gaussian_naive_bayes_method", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "GaussianNB", "metadata": {"last_modified_at": "2026-03-12T19:02:36.949141+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "get_completed_loans_fn", "definition": "def _get_completed_loans(df: pd.DataFrame) -> list[int]:\n    _df = df[form_columns].reset_index()\n    _df = _df.melt(id_vars=[\"id\"], value_vars=form_columns, var_name=\"columns\", value_name=\"value\")\n    _df[\"is_incomplete\"] = _df[\"value\"].isna() | (_df[\"value\"] == 0)\n    _df = _df.groupby([\"id\"])[[\"is_incomplete\"]].sum()\n\n    _completed_loans = _df[_df[\"is_incomplete\"] == 0].index.tolist()\n    return _completed_loans\n\nresult = _get_completed_loans", "title": "Get completed loans", "nodeClass": "variable", "moduleId": "predictions_functions_mod", "x": 60, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Returns the list of loan IDs with all required form fields completed (no nulls and no zeros). This function is the validation gate used before prediction.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297183+00:00", "last_modified_at": "2026-03-12T19:01:29.874086+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0007740000000000001, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "pre_process_new_loans_fn", "definition": "def _preprocess_new_loans(df: pd.DataFrame) -> pd.DataFrame:\n    _complete_loans = get_completed_loans_fn(df)\n\n    _df = df[form_columns].reset_index()\n    _filter = _df[\"id\"].isin(_complete_loans)\n    _df = _df[_filter]\n\n    if len(_complete_loans) > 0:\n        _age_interval = (17, 25, 35, 60, 120)\n        _age_categories = [\"Student\", \"Young\", \"Adult\", \"Senior\"]\n        _df[\"Age category\"] = pd.cut(_df[\"age\"], _age_interval, labels=_age_categories)\n\n        _job_categories = {\n            \"job_category\": [\n                \"0- unskilled and non-resident\",\n                \"1- unskilled and resident\",\n                \"2- skilled\",\n                \"3- highly skilled\",\n            ],\n            \"Job\": [0, 1, 2, 3],\n        }\n        _job_categories_df = pd.DataFrame(_job_categories)\n        _df = _df.merge(_job_categories_df, on=\"job_category\", how=\"left\").drop(columns=\"job_category\")\n\n        _df = _df.rename(\n            columns={\n                \"age\": \"Age\",\n                \"sex\": \"Sex\",\n                \"housing\": \"Housing\",\n                \"savings_account\": \"Saving accounts\",\n                \"checking_account\": \"Checking account\",\n                \"credit_amount\": \"Credit amount\",\n                \"duration\": \"Duration\",\n                \"purpose\": \"Purpose\",\n            }\n        )\n        _df = _df.drop(columns=[\"id\"])\n\n        return _df\n\n    return pd.DataFrame()\n\nresult = _preprocess_new_loans", "title": "Pre-process new loans", "nodeClass": "variable", "moduleId": "predictions_functions_mod", "x": 290, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Prepares new-loan records for ML inference: filters complete loans, derives age segments, maps job category to numeric code, and standardizes column names to match model training data.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297185+00:00", "last_modified_at": "2026-03-12T19:01:29.888798+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000733, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "normalize_new_loans_fn", "definition": "def _normalize_new_loans(df: pd.DataFrame) -> pd.DataFrame:\n    _data = pre_process_new_loans_fn(df)\n\n    if _data.empty:\n        return _data\n\n    _categorical_columns = [i for i in _data.columns if i not in numerical_columns]\n\n    for i in _categorical_columns:\n        _data = _data.merge(pd.get_dummies(_data[i], drop_first=False, prefix=i), left_index=True, right_index=True)\n\n    _normalized_columns = normalized_data.columns\n    _normalized_columns_exc = [i for i in _normalized_columns if i not in _data.columns]\n    for i in _normalized_columns_exc:\n        _data[i] = 0\n\n    _data = _data[_normalized_columns].drop(columns=\"Risk_bad\")\n\n    for i in numerical_columns:\n        _original_data_i = data[i]\n        _min = _original_data_i.min()\n        _max = _original_data_i.max()\n        _scale = 1 / (_max - _min)\n        _normalized_values = _scale * _data[i] - _min * _scale\n        _data[i] = _normalized_values\n\n    return _data\n\nresult = _normalize_new_loans", "title": "Normalize new loans", "nodeClass": "variable", "moduleId": "predictions_functions_mod", "x": 520, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Transforms preprocessed loans into the exact feature space expected by trained models: one-hot encodes categorical fields, aligns missing dummy columns, drops target leakage column, and scales numeric inputs using training min-max.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297188+00:00", "last_modified_at": "2026-03-12T19:01:29.901150+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001019, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "get_rfm_loan_prediction_fn", "definition": "def _get_rfm_loan_prediction(df: pd.DataFrame) -> pd.Series:\n    _prediction = get_loan_prediction_fn(df, random_forest_method)\n    return _prediction\n\nresult = _get_rfm_loan_prediction", "title": "Get RFM loan prediction", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 150, "z": 1, "w": "180", "h": "40", "description": "Public function to get loan risk prediction using the Random Forest model.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297191+00:00", "last_modified_at": "2026-03-12T19:02:08.622242+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00063, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "get_lrm_loan_prediction_fn", "definition": "def _get_lrm_loan_prediction(df: pd.DataFrame) -> pd.Series:\n    _prediction = get_loan_prediction_fn(df, logistic_regression_method)\n    return _prediction\n\nresult = _get_lrm_loan_prediction", "title": "Get LRM loan prediction", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 390, "z": 1, "w": "180", "h": "40", "description": "Public function to get loan risk prediction using the Logistic Regression model.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297193+00:00", "last_modified_at": "2026-03-12T19:02:27.212238+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000381, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "get_gnbm_loan_prediction_fn", "definition": "def _get_gnbm_loan_prediction(df: pd.DataFrame) -> pd.Series:\n    _prediction = get_loan_prediction_fn(df, gaussian_naive_bayes_method)\n    return _prediction\n\nresult = _get_gnbm_loan_prediction", "title": "Get GNB loan prediction", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 630, "z": 1, "w": "180", "h": "40", "description": "Public function to get loan risk prediction using the Gaussian Naive Bayes model.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297196+00:00", "last_modified_at": "2026-03-12T19:02:42.779568+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000341, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "get_loan_prediction_fn", "definition": "def _get_loan_prediction(df: pd.DataFrame, predictor) -> pd.Series:\n    _complete_new_loans = get_completed_loans_fn(df)\n\n    if len(_complete_new_loans) > 0:\n        _normalized_new_loans_data = normalize_new_loans_fn(df)\n        _predict = predictor.predict(_normalized_new_loans_data.values)\n\n        _df = pd.Series(_predict, index=_complete_new_loans)\n        _df = _df.reindex(df.index.tolist()).fillna(-1).astype(int)\n    else:\n        _df = pd.Series([-1] * len(df), index=df.index)\n\n    return _df\n\nresult = _get_loan_prediction", "title": "Get loan prediction", "nodeClass": "variable", "moduleId": "predictions_functions_mod", "x": 520, "y": 150, "z": 1, "w": "180", "h": "40", "description": "Generic prediction wrapper: validates complete loans, normalizes inputs, applies the selected model, and returns a full indexed series with -1 for incomplete rows.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297198+00:00", "last_modified_at": "2026-03-12T19:02:06.790776+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000633, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "new_loans_suggested_credit_amount_fn", "definition": "def _get_suggested_credit_amount(df: pd.DataFrame, predictor) -> pd.Series:\n    _complete_new_loans = get_completed_loans_fn(df)\n\n    if len(_complete_new_loans) > 0:\n        _complete_new_loans_index = pd.Index(_complete_new_loans, name=\"complete_new_loans\")\n        _new_loans_pre_processing = pre_process_new_loans_fn(df)\n        _normalized_new_loans_data = normalize_new_loans_fn(df)\n\n        _suggested_credit_amount = 0\n        _suggested_credit_amount_list = []\n\n        _orig_credit_amount = _new_loans_pre_processing[\"Credit amount\"]\n        _orig_credit_amount = xr.DataArray(_orig_credit_amount.values, [_complete_new_loans_index])\n\n        _original_predicts = predictor.predict(_normalized_new_loans_data.values)\n\n        _original_data_i = data[\"Credit amount\"]\n        _min = _original_data_i.min()\n        _max = _original_data_i.max()\n        _scale = 1 / (_max - _min)\n\n        _credit_amount_values = np.sort(pp.to_dataarray(credit_amount).astype(int).values)[::-1]\n\n        _i_loan_pos = 0\n        for loan in _complete_new_loans_index:\n            _original_predict = _original_predicts[_i_loan_pos]\n\n            if _original_predict == 0.0:\n                _actual_credit_amount = int(pp.subscript(_orig_credit_amount, _complete_new_loans_index, loan).values)\n                _suggested_credit_amount_list.append(_actual_credit_amount)\n            else:\n                _normalized_original_values = _normalized_new_loans_data.iloc[_i_loan_pos : _i_loan_pos + 1].copy()\n                _normalized_new_values = _normalized_original_values.copy()\n\n                _loan_original_amount = int(pp.subscript(_orig_credit_amount, _complete_new_loans_index, loan).values)\n                _lower_amounts_list = _credit_amount_values[_credit_amount_values < _loan_original_amount]\n\n                if len(_lower_amounts_list) == 0:\n                    _suggested_credit_amount_list.append(-1)\n                else:\n                    for i in range(0, len(_lower_amounts_list)):\n                        _credit_amount_to_test = int(_lower_amounts_list[i])\n                        _normalized_values = _scale * _credit_amount_to_test - _min * _scale\n                        _normalized_new_values[\"Credit amount\"] = _normalized_values\n                        _predict = predictor.predict(_normalized_new_values.values)[0]\n\n                        if _predict == 0.0:\n                            _suggested_credit_amount = _credit_amount_to_test\n                            _suggested_credit_amount_list.append(_suggested_credit_amount)\n                            break\n                        elif i == len(_lower_amounts_list) - 1:\n                            _suggested_credit_amount_list.append(-1)\n\n            _i_loan_pos = _i_loan_pos + 1\n\n        _df = pd.Series(_suggested_credit_amount_list, index=_complete_new_loans_index)\n        _df = _df.reindex(df.index.tolist()).fillna(-1).astype(int)\n    else:\n        _df = pd.Series([-1] * len(df), index=df.index)\n\n    return _df\n\nresult = _get_suggested_credit_amount", "title": "New Loans Suggested Credit Amount", "nodeClass": "variable", "moduleId": "predictions_functions_mod", "x": 520, "y": 230, "z": 1, "w": "180", "h": "40", "description": "Calculates the minimum suggested credit amount per complete loan that changes a rejected prediction into approved. Returns -1 for incomplete loans or when no lower feasible amount exists.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297201+00:00", "last_modified_at": "2026-03-12T19:02:10.916137+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001241, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "new_loans_suggested_credit_amount_rfm_fn", "definition": "def _get_suggested_credit_amount_rfm(df: pd.DataFrame) -> pd.Series:\n    _suggested_credit = new_loans_suggested_credit_amount_fn(df, random_forest_method)\n    return _suggested_credit\n\nresult = _get_suggested_credit_amount_rfm", "title": "New Loans Suggested Credit Amount - RFM", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 230, "z": 1, "w": "180", "h": "40", "description": "Public function to get suggested credit amount using Random Forest decisions.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297204+00:00", "last_modified_at": "2026-03-12T19:02:19.123126+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000356, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "new_loans_suggested_credit_amount_lrm_fn", "definition": "def _get_suggested_credit_amount_lrm(df: pd.DataFrame) -> pd.Series:\n    _suggested_credit = new_loans_suggested_credit_amount_fn(df, logistic_regression_method)\n    return _suggested_credit\n\nresult = _get_suggested_credit_amount_lrm", "title": "New Loans Suggested Credit Amount - LRM", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 470, "z": 1, "w": "180", "h": "40", "description": "Public function to get suggested credit amount using Logistic Regression decisions.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297207+00:00", "last_modified_at": "2026-03-12T19:02:31.554426+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000257, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "new_loans_suggested_credit_amount_gnbm_fn", "definition": "def _get_suggested_credit_amount_gnbm(df: pd.DataFrame) -> pd.Series:\n    _suggested_credit = new_loans_suggested_credit_amount_fn(df, gaussian_naive_bayes_method)\n    return _suggested_credit\n\nresult = _get_suggested_credit_amount_gnbm", "title": "New Loans Suggested Credit Amount - GNBM", "nodeClass": "outputnode", "moduleId": "predictions_functions_mod", "x": 750, "y": 710, "z": 1, "w": "180", "h": "40", "description": "Public function to get suggested credit amount using Gaussian Naive Bayes decisions.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "function", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297209+00:00", "last_modified_at": "2026-03-12T19:02:45.067967+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000245, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}]}