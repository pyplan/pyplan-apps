{"nodeList": [{"identifier": "logistic_regression_method", "definition": "from sklearn.linear_model import LogisticRegression\n\n_params = parameters_lrm\n_model = LogisticRegression(\n    random_state=fixed_random_state,\n    solver=\"liblinear\",\n    penalty=_params[\"penalty\"],\n    C=_params[\"C\"],\n)\n_trained_model = _model.fit(x_train, y_train)\n\nresult = _trained_model", "title": "Logistic Regression Method", "nodeClass": "variable", "moduleId": "logistic_regression_method_mod", "x": 340, "y": 210, "z": 1, "w": "180", "h": "40", "description": "Trains and returns the Logistic Regression classifier using configured regularization parameters and training data.", "units": null, "color": "#CB98FF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "LogisticRegression", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297052+00:00", "last_modified_at": "2026-03-13T13:11:29.570353+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00225, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "accuracy_lrm", "definition": "from sklearn.metrics import accuracy_score\n\nresult = accuracy_score(y_test, model_prediction_lrm)", "title": "Accuracy - Logistic Regression Method", "nodeClass": "outputnode", "moduleId": "logistic_regression_method_mod", "x": 340, "y": 370, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486593+00:00", "last_modified_at": "2026-03-12T18:38:33.338889+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000982, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "confusion_matrix_lrm", "definition": "from sklearn.metrics import confusion_matrix\n\n_cm = confusion_matrix(y_test, model_prediction_lrm)\n\n# Create DataArray from confusion matrix, replacing 0 and 1 index by 'Good' and 'Bad'\nresult = xr.DataArray(_cm, coords = {'Actual': ['Actual - Good', 'Actual - Bad'], 'Predicted': ['Predicted - Good', 'Predicted - Bad']}, dims = ['Actual', 'Predicted'])", "title": "Confusion Matrix - Logistic Regression Method", "nodeClass": "report", "moduleId": "logistic_regression_method_mod", "x": 340, "y": 460, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataArray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297064+00:00", "last_modified_at": "2026-03-12T18:38:38.393962+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.001151, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "probability_prediction_lrm", "definition": "result = logistic_regression_method.predict_proba(x_test)[:,1]", "title": "Probability Prediction - Logistic Regression Method", "nodeClass": "variable", "moduleId": "logistic_regression_method_mod", "x": 580, "y": 290, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297072+00:00", "last_modified_at": "2026-03-12T18:38:42.034691+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000176, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "roc_curve_lrm", "definition": "from sklearn.utils import resample\nfrom sklearn.metrics import roc_curve\nimport plotly.graph_objects as go\n\n_fpr, _tpr, thresholds = roc_curve(y_test, probability_prediction_lrm)\n\n_trace0 = go.Scatter(\n    x = [0, 1],\n    y = [0, 1],\n    name = 'Random'\n    )\n_trace1 = go.Scatter(\n    x = _fpr,\n    y = _tpr,\n    name = 'ROC Curve'\n    )\n\n_data = [_trace0, _trace1]\n\n_layout = go.Layout(\n    yaxis = dict(title = 'True Positive Rate'),\n    xaxis = dict(title = 'False Positive Rate'),\n    )\n\n_fig = go.Figure(_data, _layout)\n_fig.layout.xaxis.update({'anchor': 'x', 'domain': [.05, 0.95]})\n_fig.layout.yaxis.update({'anchor': 'y', 'domain': [.05, 0.95]})\n\nresult = _fig", "title": "ROC Curve - Logistic Regression Method", "nodeClass": "report", "moduleId": "logistic_regression_method_mod", "x": 580, "y": 370, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "Figure", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297076+00:00", "last_modified_at": "2026-03-12T18:38:46.426293+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.002062, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "model_prediction_lrm", "definition": "result = logistic_regression_method.predict(x_test)", "title": "Model Prediction - Logistic Regression Method", "nodeClass": "variable", "moduleId": "logistic_regression_method_mod", "x": 340, "y": 290, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297080+00:00", "last_modified_at": "2026-03-12T18:38:30.876838+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.000399, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "precision_score_lrm", "definition": "from sklearn.metrics import precision_score\n\nresult = precision_score(y_test, model_prediction_lrm)", "title": "Precision Score - Logistic Regression Method", "nodeClass": "outputnode", "moduleId": "logistic_regression_method_mod", "x": 580, "y": 460, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486598+00:00", "last_modified_at": "2026-03-12T18:39:08.825919+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00232, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "recall_score_lrm", "definition": "from sklearn.metrics import recall_score\n\nresult = recall_score(y_test, model_prediction_lrm)", "title": "Recall - Logistic Regression Method", "nodeClass": "outputnode", "moduleId": "logistic_regression_method_mod", "x": 580, "y": 550, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "float", "metadata": {"last_execution_at": "2026-03-18T13:20:00.486603+00:00", "last_modified_