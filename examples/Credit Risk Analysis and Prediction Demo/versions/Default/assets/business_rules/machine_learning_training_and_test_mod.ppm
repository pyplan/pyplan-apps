{"nodeList": [{"identifier": "x_variable", "definition": "# Split data: keep all feature columns except target 'Risk_bad'\n_df = normalized_data\n_x = _df.drop(columns=[\"Risk_bad\"], errors=\"ignore\").to_numpy(dtype=np.float32, copy=False)\n\nresult = _x", "title": "X Variable", "nodeClass": "variable", "moduleId": "machine_learning_training_and_test_mod", "x": 340, "y": 270, "z": 1, "w": "180", "h": "40", "description": "Returns feature matrix X as a NumPy array (float32) to reduce memory usage and speed up model training.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_modified_at": "2026-03-13T13:49:06.561352+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-18T13:19:10.297012+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.00021799999999999944, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "y_variable", "definition": "# Split data. Keeps 'Risk_bad' column (target)\n_df = normalized_data\nif \"Risk_bad\" not in _df.columns:\n    raise ValueError(\"Column 'Risk_bad' was not found in normalized_data.\")\n\n_y = _df[\"Risk_bad\"].to_numpy(dtype=np.int8, copy=False)\n\nresult = _y", "title": "Y Variable", "nodeClass": "variable", "moduleId": "machine_learning_training_and_test_mod", "x": 340, "y": 360, "z": 1, "w": "180", "h": "40", "description": "Returns target vector y as NumPy int8 and validates that the expected target column exists.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297017+00:00", "last_modified_at": "2026-03-13T13:49:08.370616+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 8.999999999999999e-05, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "train_test_array", "definition": "from sklearn.model_selection import train_test_split\n\n# Validate split ratio\n_test_size = float(test_size_input1)\nif _test_size <= 0 or _test_size >= 1:\n    raise ValueError(\"Test Size Input must be between 0 and 1 (exclusive).\")\n\n# Split X and Y into train and test version (stratified for class balance)\n_x_train, _x_test, _y_train, _y_test = train_test_split(\n    x_variable,\n    y_variable,\n    test_size=_test_size,\n    random_state=fixed_random_state,\n    stratify=y_variable\n)\n\n# Create dictionary with the four tables\n_result = {\"x_train\": _x_train, \"x_test\": _x_test, \"y_train\": _y_train, \"y_test\": _y_test}\n\nresult = _result", "title": "Train / Test Array", "nodeClass": "variable", "moduleId": "machine_learning_training_and_test_mod", "x": 570, "y": 180, "z": 1, "w": "180", "h": "40", "description": "Splits X/y into train and test sets with parameter validation and class-stratified sampling for more stable model evaluation.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "dict", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297021+00:00", "last_modified_at": "2026-03-13T13:49:13.423479+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0011539999999999994, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "x_train", "definition": "# Training features after SMOTE balancing\n_x_train = train_arrays_smote[\"os_smote_x\"]\n\nresult = _x_train", "title": "X Train", "nodeClass": "outputnode", "moduleId": "machine_learning_training_and_test_mod", "x": 60, "y": 180, "z": 1, "w": "180", "h": "40", "description": "Matriz de variables predictoras del set de entrenamiento balanceado con SMOTE. Se utiliza para entrenar el modelo Gaussian Naive Bayes.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "ndarray", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297024+00:00", "last_modified_at": "2026-03-13T13:49:04.721415+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00015500000000000236, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "y_train", "definition": "# Training target after SMOTE balancing\n_y_train = train_arrays_smote[\"os_smote_y\"]\n\nresult = _y_train", "title": "Y Train", "nodeClass": "outputnode", "module