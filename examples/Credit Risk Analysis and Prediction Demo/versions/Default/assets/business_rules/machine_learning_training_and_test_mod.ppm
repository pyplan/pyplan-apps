ill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-12T18:33:29.435133+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "gaussian_naive_bayes_method_mod", "definition": "", "title": "Gaussian Naive Bayes Method", "nodeClass": "module", "moduleId": "machine_learning_training_and_test_mod", "x": 850, "y": 430, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#6699FF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-12T18:33:27.487749+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "metrics_by_ml_method", "definition": "# Sets of metrics by Machine Learning method\n_rf = [accuracy_rfm, precision_score_rfm, recall_score_rfm, f1_score_rfm, score_rfm]\n_lr = [accuracy_lrm, precision_score_lrm, recall_score_lrm, f1_score_lrm, score_lrm]\n_gnb = [accuracy_gnb, precision_score_gnb, recall_score_gnb, f1_score_gnb, score_gnb]\n\n# Create DataArray indexed by Machine Learning method and Metric\nresult = xr.DataArray([_rf, _lr, _gnb], [machine_learning_methods, metrics])", "title": "Metrics by Machine Learning Method", "nodeClass": "report", "moduleId": "machine_learning_training_and_test_mod", "x": 1070, "y": 350, "z": 1, "w": "180", "h": "40", "description": null, "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataArray", "metadata": {"last_execution_at": "2026-03-18T13:20:00.673956+00:00", "last_modified_at": "2026-03-18T13:15:03.325459+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.002399, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "train_arrays_smote", "definition": "from imblearn.over_sampling import SMOTE\n\n# Create instance\n_os = SMOTE(random_state=fixed_random_state)\n\n# Fit / resample\n_os_smote_x, _os_smote_y = _os.fit_resample(\n    train_test_array[\"x_train\"],\n    train_test_array[\"y_train\"]\n)\n\n# Normalize output dtypes for downstream estimators\n_os_smote_x = np.asarray(_os_smote_x, dtype=np.float32)\n_os_smote_y = np.asarray(_os_smote_y, dtype=np.int8)\n\n# Create dictionary with the two tables\n_result = {\"os_smote_x\": _os_smote_x, \"os_smote_y\": _os_smote_y}\n\nresult = _result", "title": "Train Array Synthetic Minority Oversampling TEchnique (SMOTE)", "nodeClass": "variable", "moduleId": "machine_learning_training_and_test_mod", "x": 340, "y": 180, "z": 1, "w": "180", "h": "40", "description": "Applies SMOTE to training data and standardizes output dtypes for better memory footprint and model compatibility.", "units": 