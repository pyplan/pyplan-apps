{"nodeList": [{"identifier": "normalized_data", "definition": "from sklearn.preprocessing import MinMaxScaler\n\n# Remove helper columns not needed for modeling\n_data = data.drop(columns=[\"value\", \"Job category\"], errors=\"ignore\")\n\n# Build dummies efficiently (single pass) keeping both Risk classes\n_categorical_no_risk = [\n    _col for _col in categorical_columns\n    if _col != \"Risk\" and _col in _data.columns\n]\n_data = pd.get_dummies(_data, columns=_categorical_no_risk, drop_first=True)\n\nif \"Risk\" in categorical_columns and \"Risk\" in _data.columns:\n    _risk_dummies = pd.get_dummies(_data[\"Risk\"], prefix=\"Risk\", drop_first=False)\n    _data = pd.concat([_data.drop(columns=[\"Risk\"]), _risk_dummies], axis=1)\n\n# Keep only Risk_bad if both classes exist\n_data = _data.drop(columns=[\"Risk_good\"], errors=\"ignore\")\n\n# Ensure numeric dtypes for model compatibility and memory efficiency\n_data = _data.apply(pd.to_numeric, errors=\"coerce\").fillna(0.0)\n\n# Normalize numerical columns and return DataFrame\n_scaler = MinMaxScaler(feature_range=(0, 1))\n_data_normalized = _scaler.fit_transform(_data)\n_result = pd.DataFrame(_data_normalized, columns=_data.columns, index=_data.index)\n\nresult = _result", "title": "Normalized Data", "nodeClass": "variable", "moduleId": "data_exploration_analysis_mod", "x": 340, "y": 100, "z": 1, "w": "180", "h": "40", "description": "Builds a model-ready dataset by encoding categorical columns, preserving the target encoding logic, coercing to numeric safely, and applying Min-Max normalization.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297211+00:00", "last_modified_at": "2026-03-12T18:51:47.605354+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.00498, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "data_info", "definition": "# Summary statistics for exploration\n_description = data.describe(include=\"all\")\n\nresult = _description", "title": "Data info", "nodeClass": "report", "moduleId": "data_exploration_analysis_mod", "x": 70, "y": 170, "z": 1, "w": "180", "h": "40", "description": "Returns descriptive statistics of the enriched dataset for quick data profiling.", "units": null, "color": "#CCCCCC", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_modified_at": "2026-03-12T18:13:31.195999+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-12T19:15:09.799854+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.036976, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "a8ae54b33b3314147bd6f491e12db9a2f", "definition": "result = data", "title": "Data (with new columns and loans)", "nodeClass": "alias", "moduleId": "data_exploration_analysis_mod", "x": 70, "y": 100, "z": 1, "w": "180", "h": "40", "description": "Creates a cleaned and enriched dataset with helper fields for analysis (value, age category, and job category), and fills missing account information.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": "data", "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-13T13:01:06.400509+00:00", "last_modified_at": "2026-03-12T18:10:57.730967+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0002640000000000023, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "node1_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy", "definition": "result = 0", "title": "Correlations", "nodeClass": "text", "moduleId": "data_exploration_analysis_mod", "x": 310, "y": 80, "z": -1, "w": "240", "h": "150", "description": null, "units": null, "color": "#cccccc", "errorInDef": false, "nodeInfo": {"showInputs": 0, "showOutputs": 0, "showLabel": 1, "showBorder": 0, "fill": 1, "useNodeFont": 0}, "nodeFont": "", "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-12T18:11:06.010923+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "node1_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy", "definition": "result = 0", "title": "Data", "nodeClass": "text", "moduleId": "data_exploration_ana