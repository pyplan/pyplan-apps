null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "Figure", "metadata": {"last_modified_at": "2026-03-12T18:13:31.312896+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-12T18:13:54.460630+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.090076, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}]}