{"nodeList": [{"identifier": "data", "definition": "_dataframe = original_data.copy()\n\n# Helper column for aggregations/counts\n_dataframe[\"value\"] = 1.0\n\n# Age segmentation\n_age_bins = [17, 25, 35, 60, 120]\n_age_labels = [\"Student\", \"Young\", \"Adult\", \"Senior\"]\n_dataframe[\"Age category\"] = pd.cut(\n    _dataframe[\"Age\"],\n    bins=_age_bins,\n    labels=_age_labels\n)\n\n# Job category labels\n_job_labels = {\n    0: \"0- unskilled and non-resident\",\n    1: \"1- unskilled and resident\",\n    2: \"2- skilled\",\n    3: \"3- highly skilled\"\n}\n_dataframe[\"Job category\"] = _dataframe[\"Job\"].map(_job_labels)\n\n# Fill missing account information in one pass\n_dataframe[[\"Saving accounts\", \"Checking account\"]] = _dataframe[[\"Saving accounts\", \"Checking account\"]].fillna(\"no info\")\n\nresult = _dataframe", "title": "Data (with new columns and loans)", "nodeClass": "variable", "moduleId": "data_mod", "x": 60, "y": 200, "z": 1, "w": "180", "h": "40", "description": "Creates a cleaned and enriched dataset with helper fields for analysis (value, age category, and job category), and fills missing account information.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": true, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297142+00:00", "last_modified_at": "2026-03-12T18:13:30.936238+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.004715, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "node1_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy_copy", "definition": "result = 0", "title": "Data", "nodeClass": "text", "moduleId": "data_mod", "x": 30, "y": 60, "z": -1, "w": "460", "h": "210", "description": null, "units": null, "color": "#EEEEEE", "errorInDef": false, "nodeInfo": {"showInputs": 0, "showOutputs": 0, "showLabel": 1, "showBorder": 0, "fill": 1, "useNodeFont": 1}, "nodeFont": "Helvetica,21", "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": null, "_resultType": null, "metadata": {"last_modified_at": "2026-03-12T18:10:15.742342+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "data_overview_post_manip", "definition": "_dataframe = data\n_overview = build_data_overview(_dataframe)\n\nresult = _overview", "title": "Data Overview (Post Manipulation", "nodeClass": "report", "moduleId": "data_mod", "x": 270, "y": 200, "z": 1, "w": "180", "h": "40", "description": "Data quality and loan-risk summary after data enrichment and cleaning.", "units": null, "color": "#cccccc", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-12T18:10:22.106569+00:00", "last_modified_at": "2026-03-12T18:09:58.614978+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.0037170000000000003, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "data_overview", "definition": "_dataframe = original_data\n_overview = build_data_overview(_dataframe)\n\nresult = _overview", "title": "Data Overview", "nodeClass": "report", "moduleId": "data_mod", "x": 270, "y": 140, "z": 1, "w": "180", "h": "40", "description": "Data quality and loan-risk summary based on the original dataset.", "units": null, "color": "#cccccc", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_modified_at": "2026-03-12T18:10:12.534384+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-12T19:15:09.799751+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.003943, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "original_data", "definition": "_file_path = current_path + '/inputs/german_credit_data.csv'\n_dataframe = pd.read_csv(_file_path, index_col=0)\n\nresult = _dataframe", "title": "Original Data", "nodeClass": "datareading", "moduleId": "data_mod", "x": 60, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Reads the original German Credit dataset from the app input folder.", "units": null, "color": null, "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "DataFrame", "metadata": {"last_execution_at": "2026-03-18T13:19:10.297148+00:00", "last_modified_at": "2026-03-12T18:23:30.984183+00:00", "last_user_to_modify": "Fabian Brussa"}, "connection_metadata": {}, "lastEvaluationTime": 0.016482999999999998, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}, {"identifier": "build_data_overview", "definition": "def _build_overview(_dataframe: pd.DataFrame) -> pd.DataFrame:\n    _unique_values = _dataframe.nunique(dropna=False)\n    _data_types = _dataframe.dtypes.astype(str)\n    _null_values = _dataframe.isnull().sum()\n    _empty_values = _dataframe.apply(\n        lambda _col: _col.astype(str).str.strip().eq('').sum()\n        if _col.dtype == 'object' else 0\n    )\n\n    _overview = pd.DataFrame({\n        'Unique values': _unique_values,\n        'Data type': _data_types,\n        'Null values': _null_values,\n        'Empty values': _empty_values\n    })\n\n    _risk_series = _dataframe['Risk'].astype(str).str.lower()\n    _good_loans = _risk_series.eq('good').sum()\n    _bad_loans = _risk_series.eq('bad').sum()\n    _total_loans = _good_loans + _bad_loans\n\n    _good_loans_pc = (_good_loans / _total_loans) if _total_loans > 0 else 0\n    _bad_loans_pc = (_bad_loans / _total_loans) if _total_loans > 0 else 0\n\n    _risk_summary = pd.DataFrame({\n        'Unique values': [_good_loans, _good_loans_pc, _bad_loans, _bad_loans_pc, _total_loans],\n        'Data type': ['NA', 'NA', 'NA', 'NA', 'NA'],\n        'Null values': ['NA', 'NA', 'NA', 'NA', 'NA'],\n        'Empty values': ['NA', 'NA', 'NA', 'NA', 'NA']\n    }, index=['Good loans', 'Good loans %', 'Bad loans', 'Bad loans %', 'Number of observations'])\n\n    _result_df = pd.concat([_overview, _risk_summary])\n    return _result_df\n\nresult = _build_overview", "title": "Build Data Overview", "nodeClass": "variable", "moduleId": "data_mod", "x": 270, "y": 80, "z": 1, "w": "180", "h": "40", "description": "Reusable function to build a standardized data quality and risk overview for any credit dataset.", "units": null, "color": "#4CBCFF", "errorInDef": false, "nodeInfo": {"showInputs": 1, "showOutputs": 1, "showLabel": 1, "showBorder": 1, "fill": 1, "useNodeFont": 0}, "nodeFont": null, "numberFormat": null, "originalId": null, "extraData": null, "picture": null, "evaluateOnStart": false, "releaseMemory": false, "defaultView": null, "prefixIdentifier": null, "hierarchy": null, "hasOutputsOutsideModule": false, "_isNodeCircular": false, "_resultType": "function", "metadata": {"created_at": "2026-03-12T18:09:19.557424+00:00", "last_modified_at": "2026-03-12T18:10:07.091015+00:00", "last_user_to_modify": "Fabian Brussa", "last_execution_at": "2026-03-12T19:15:09.799932+00:00"}, "connection_metadata": {}, "lastEvaluationTime": 0.001129, "title_translations": null, "description_translations": null, "persistenceType": "in_definition"}]}